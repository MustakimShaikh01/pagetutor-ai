# ============================================================
# PageTutor AI - Environment Variables Template
# Author: Mustakim Shaikh (https://github.com/MustakimShaikh01)
#
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in all values
#   3. NEVER commit .env to git
# ============================================================

# ----------------------------------------------------------
# App Config
# ----------------------------------------------------------
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars

# ----------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------
POSTGRES_PASSWORD=pagetutor_secret_change_me
DATABASE_URL=postgresql+asyncpg://pagetutor:pagetutor_secret_change_me@localhost:5432/pagetutor_db

# ----------------------------------------------------------
# Redis
# ----------------------------------------------------------
REDIS_PASSWORD=redis_secret_change_me
REDIS_URL=redis://:redis_secret_change_me@localhost:6379/0
CELERY_BROKER_URL=redis://:redis_secret_change_me@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:redis_secret_change_me@localhost:6379/2

# ----------------------------------------------------------
# MinIO (S3-compatible storage)
# ----------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123_change_me
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123_change_me
S3_BUCKET_NAME=pagetutor-uploads
S3_REGION=us-east-1
S3_CDN_BASE_URL=https://cdn.pagetutor.ai

# ----------------------------------------------------------
# LLM (vLLM / TGI)
# ----------------------------------------------------------
LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.2
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=120
LLM_BATCH_SIZE=8

# ----------------------------------------------------------
# Qdrant
# ----------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ----------------------------------------------------------
# JWT / Cookie Security
# ----------------------------------------------------------
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
COOKIE_SECURE=false        # Set to true in production (HTTPS)
COOKIE_HTTPONLY=true
COOKIE_SAMESITE=lax

# ----------------------------------------------------------
# Rate Limiting
# ----------------------------------------------------------
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
FREE_TIER_DAILY_JOBS=5
PAID_TIER_DAILY_JOBS=100

# ----------------------------------------------------------
# Upload Limits
# ----------------------------------------------------------
MAX_FILE_SIZE_MB=50
MAX_PAGE_COUNT=500

# ----------------------------------------------------------
# Worker Concurrency
# ----------------------------------------------------------
LLM_WORKER_CONCURRENCY=4
CPU_WORKER_CONCURRENCY=8
EMBED_WORKER_CONCURRENCY=4

# ----------------------------------------------------------
# OAuth (optional)
# ----------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ----------------------------------------------------------
# Email (SMTP)
# ----------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM=noreply@pagetutor.ai

# ----------------------------------------------------------
# Monitoring
# ----------------------------------------------------------
GRAFANA_PASSWORD=grafana_admin_change_me
FLOWER_USER=admin
FLOWER_PASSWORD=flower_admin_change_me

# ----------------------------------------------------------
# Admin
# ----------------------------------------------------------
FIRST_SUPERUSER_EMAIL=admin@pagetutor.ai
FIRST_SUPERUSER_PASSWORD=AdminPass@123!

# ----------------------------------------------------------
# Frontend
# ----------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
